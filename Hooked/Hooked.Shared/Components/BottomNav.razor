@using Microsoft.AspNetCore.Components
@inject NavigationManager NavigationManager

<nav class="bottom-nav">
    <a href="/feed" class="@GetNavItemClass("/feed")" title="Feed" aria-label="Feed">
        <span class="nav-icon" aria-hidden="true">
            <AppIcon Name='@GetNavIcon("/feed", "feed", "feed")' Size="20" />
        </span>
    </a>
    <a href="/arscanner" class="@GetNavItemClass("/arscanner")" title="Scan Fish" aria-label="Scan Fish">
        <span class="nav-icon" aria-hidden="true">
            <AppIcon Name='@GetNavIcon("/arscanner", "scan", "scan")' Size="20" />
        </span>
    </a>
    <a href="/map" class="@GetNavItemClass("/map")" title="Map" aria-label="Map">
        <span class="nav-icon" aria-hidden="true">
            <AppIcon Name='@GetNavIcon("/map", "map", "compass")' Size="20" />
        </span>
    </a>
    <a href="/" class="@($"{GetNavItemClass("/")} nav-home")" title="Home" aria-label="Home">
        <span class="nav-icon" aria-hidden="true">
            <AppIcon Name='@GetNavIcon("/", "home", "home")' Size="22" />
        </span>
    </a>
    <a href="/fishdex" class="@GetNavItemClass("/fishdex")" title="Fish Dictionary" aria-label="FishDex">
        <span class="nav-icon" aria-hidden="true">
            <AppIcon Name='@GetNavIcon("/fishdex", "fish", "book-open")' Size="20" />
        </span>
    </a>
    <a href="/leaderboard" class="@GetNavItemClass("/leaderboard")" title="Leaderboard" aria-label="Leaderboard">
        <span class="nav-icon" aria-hidden="true">
            <AppIcon Name='@GetNavIcon("/leaderboard", "trophy", "medal")' Size="20" />
        </span>
    </a>
    <a href="/profile" class="@GetNavItemClass("/profile")" title="Profile" aria-label="Profile">
        <span class="nav-icon" aria-hidden="true">
            <AppIcon Name='@GetNavIcon("/profile", "user", "user-circle")' Size="20" />
        </span>
    </a>
</nav>

@code {
    private string GetNavItemClass(string href)
    {
        var relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        var currentPath = $"/{relativePath.Split('?', '#')[0]}".TrimEnd('/');
        var normalizedHref = href.TrimEnd('/');

        if (string.IsNullOrEmpty(currentPath))
        {
            currentPath = "/";
        }

        if (string.IsNullOrEmpty(normalizedHref))
        {
            normalizedHref = "/";
        }

        var isActive = normalizedHref == "/"
            ? currentPath.Equals("/", StringComparison.OrdinalIgnoreCase)
            : currentPath.Equals(normalizedHref, StringComparison.OrdinalIgnoreCase) ||
              currentPath.StartsWith($"{normalizedHref}/", StringComparison.OrdinalIgnoreCase);

        return isActive
            ? "nav-item active"
            : "nav-item";
    }

    private string GetNavIcon(string href, string defaultIcon, string activeIcon)
    {
        var relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        var currentPath = $"/{relativePath.Split('?', '#')[0]}".TrimEnd('/');
        var normalizedHref = href.TrimEnd('/');

        if (string.IsNullOrEmpty(currentPath))
        {
            currentPath = "/";
        }

        if (string.IsNullOrEmpty(normalizedHref))
        {
            normalizedHref = "/";
        }

        var isActive = normalizedHref == "/"
            ? currentPath.Equals("/", StringComparison.OrdinalIgnoreCase)
            : currentPath.Equals(normalizedHref, StringComparison.OrdinalIgnoreCase) ||
              currentPath.StartsWith($"{normalizedHref}/", StringComparison.OrdinalIgnoreCase);

        return isActive ? activeIcon : defaultIcon;
    }
}
