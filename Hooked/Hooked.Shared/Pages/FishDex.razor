@page "/fishdex"
@using Hooked.Shared.Services
@inject IFishDexService FishDexService
@inject ISocialService SocialService
@inject NavigationManager NavigationManager

<PageTitle>FishDex</PageTitle>

<div class="mobile-shell fishdex-shell">
    <TopNavBar Subtitle="Species Collection" />

    @if (_isLoading)
    {
        <section class="ocean-glass fishdex-state">
            <p class="muted">Loading FishDex…</p>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(_loadError))
    {
        <section class="ocean-glass fishdex-state">
            <h1>FishDex unavailable</h1>
            <p class="muted">@_loadError</p>
            <button class="action secondary" type="button" @onclick="LoadAsync">Retry</button>
        </section>
    }
    else
    {
        <div class="fishdex-summary-pill ocean-glass">
            <div class="summary-item">
                <svg class="summary-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z" />
                </svg>
                <div class="summary-text">
                    <span class="val">@_unlockedSpeciesCount <span style="font-size:0.8rem;color:var(--text-soft);font-weight:500;">/ @_discoveredSpeciesCount</span></span>
                    <span class="lbl">Unlocked</span>
                </div>
            </div>

            <div class="summary-divider"></div>

            <div class="summary-item">
                <svg class="summary-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" />
                </svg>
                <div class="summary-text">
                    <span class="val">@_completionPercentText</span>
                    <span class="lbl">Completed</span>
                </div>
            </div>
        </div>

        @if (_speciesCards.Count == 0)
        {
            <section class="ocean-glass fishdex-state">
                <p class="muted">No species have been discovered yet. Be the first to scan and log one.</p>
            </section>
        }
        else
        {
            <section class="fishdex-grid">
                @foreach (var speciesCard in _speciesCards)
                {
                    var cardClass = speciesCard.IsUnlocked ? "fish-card unlocked" : "fish-card locked";

                    <article class="ocean-glass @cardClass" @onclick="() => OpenSpeciesDetails(speciesCard)">
                        @if (speciesCard.IsUnlocked && speciesCard.CatchCount > 0)
                        {
                            <div class="fish-catch-badge">@speciesCard.CatchCount</div>
                        }

                        <div class="fish-image-shell">
                            @if (!string.IsNullOrWhiteSpace(speciesCard.IllustrationImageUrl))
                            {
                                <img src="@speciesCard.IllustrationImageUrl"
                                     alt="@speciesCard.CommonName"
                                     class="fish-image" />
                            }
                            else
                            {
                                <div class="fish-image-fallback">?</div>
                            }
                        </div>

                        <div class="fish-card-content">
                            <h2 class="fish-name">@(speciesCard.IsUnlocked ? speciesCard.CommonName : "???")</h2>

                            @if (speciesCard.IsUnlocked)
                            {
                                <div class="fish-pb">@FormatPersonalBestCompact(speciesCard.PersonalBestLengthMeters)</div>
                            }
                        </div>
                    </article>
                }
            </section>
        }
    }

    <BottomNav />
</div>

@if (_selectedSpecies != null)
{
    <div class="fishdex-modal-backdrop" @onclick="CloseDetails">
        <div class="fishdex-modal-content ocean-glass" @onclick:stopPropagation>
            <button class="modal-close-btn" @onclick="CloseDetails">×</button>

            <div class="modal-header">
                <div class="modal-image-shell">
                    @if (!string.IsNullOrWhiteSpace(_selectedSpecies.IllustrationImageUrl))
                    {
                        <img src="@_selectedSpecies.IllustrationImageUrl" alt="@_selectedSpecies.CommonName" class="modal-image" />
                    }
                    else
                    {
                        <div class="fish-image-fallback">?</div>
                    }
                </div>
                <h2>@(_selectedSpecies.IsUnlocked ? _selectedSpecies.CommonName : "???")</h2>

                @if (_selectedSpecies.IsUnlocked && !string.IsNullOrWhiteSpace(_selectedSpecies.ScientificName))
                {
                    <div class="modal-scientific">@_selectedSpecies.ScientificName</div>
                }
            </div>

            <div class="modal-body">
                @if (_selectedSpecies.IsUnlocked)
                {
                    <div class="modal-stats">
                        <div class="stat-box">
                            <span class="stat-title">Caught</span>
                            <span class="stat-val">@_selectedSpecies.CatchCount</span>
                        </div>
                        <div class="stat-box">
                            <span class="stat-title">Personal Best</span>
                            <span class="stat-val">@FormatLength(_selectedSpecies.PersonalBestLengthMeters)</span>
                        </div>
                    </div>

                    <h3 class="history-title">Catch History</h3>
                    <div class="catch-history-list">
                        @if (_selectedSpecies.Catches.Count == 0)
                        {
                            <p class="muted center">No catches logged yet.</p>
                        }
                        else
                        {
                            @foreach (var fishCatch in _selectedSpecies.Catches.OrderByDescending(c => c.CaughtAt))
                            {
                                <div class="catch-row">
                                    <span class="catch-date">@fishCatch.CaughtAt.ToLocalTime().ToString("g")</span>
                                    <span class="catch-weight">@FormatLength(fishCatch.LengthMeters)</span>
                                </div>
                            }
                        }
                    </div>
                }
                else
                {
                    <p class="muted center">Catch this species to reveal its details.</p>
                }
            </div>
        </div>
    </div>
}

@code {
    private bool _isLoading = true;
    private string? _loadError;
    private List<FishDexSpeciesCardDto> _speciesCards = [];
    private int _discoveredSpeciesCount;
    private int _unlockedSpeciesCount;
    private string _completionPercentText = "0%";
    private FishDexSpeciesCardDto? _selectedSpecies;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private void OpenSpeciesDetails(FishDexSpeciesCardDto species)
    {
        _selectedSpecies = species;
    }

    private void CloseDetails()
    {
        _selectedSpecies = null;
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _loadError = null;

        try
        {
            var currentUser = await SocialService.ResolveCurrentUserAsync();
            var fishDexOverview = await FishDexService.GetFishDexOverviewAsync(currentUser.Id);

            _speciesCards = fishDexOverview.Species.ToList();
            _discoveredSpeciesCount = _speciesCards.Count;
            _unlockedSpeciesCount = _speciesCards.Count(species => species.IsUnlocked);
            _completionPercentText = _discoveredSpeciesCount == 0
                ? "0%"
                : $"{Math.Round((_unlockedSpeciesCount * 100.0) / _discoveredSpeciesCount):0}%";
        }
        catch (Exception ex)
        {
            _speciesCards = [];
            _discoveredSpeciesCount = 0;
            _unlockedSpeciesCount = 0;
            _completionPercentText = "0%";
            _loadError = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void OpenScanner()
    {
        NavigationManager.NavigateTo("/arscanner");
    }

    private static string FormatLength(double? lengthMeters)
    {
        return lengthMeters.HasValue ? $"{lengthMeters.Value:F2} m" : "Length —";
    }

    private static string FormatPersonalBest(double? personalBestLengthMeters)
    {
        return personalBestLengthMeters.HasValue ? $"PB {personalBestLengthMeters.Value:F2} m" : "PB —";
    }

    private static string FormatPersonalBestCompact(double? personalBestLengthMeters)
    {
        return personalBestLengthMeters.HasValue ? $"PB: {personalBestLengthMeters.Value:F2}m" : "PB: —";
    }
}
