@page "/arscanner"
@using Hooked.Shared.Services
@using Hooked.Shared.Services.AI
@using Hooked.Shared.Services.Camera
@using System.Globalization
@using Microsoft.AspNetCore.Components.Forms
@inject IFishDexService FishDexService
@inject ISocialService SocialService
@inject IGeminiFishSpeciesService GeminiService
@inject IReferenceMeasurementService MeasurementService
@inject ICameraCalibrationService CalibrationService
@inject ILocationService LocationService
@inject IPhotoCaptureService PhotoCaptureService
@inject NavigationManager NavigationManager

<PageTitle>AI Scanner</PageTitle>

<div class="mobile-shell scanner-shell">
    <TopNavBar Subtitle="AI Catch Scanner" />

    <section class="ocean-glass scanner-card">
        <div class="badge-pill">Camera + AI</div>
        <h1>Scan and log your catch</h1>
        <p class="muted">Use your camera first for the best scan quality, or upload from your gallery.</p>

        @if (string.IsNullOrWhiteSpace(_photoPreviewUrl))
        {
            <div class="scanner-photo-layout">
                <button class="action primary scanner-capture"
                        type="button"
                        disabled="@_isScanning"
                        @onclick="CapturePhotoAsync">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 1.5rem; height: 1.5rem; margin-right: 0.5rem;"><path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 0 1 5.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 0 0-1.134-.175 2.31 2.31 0 0 1-1.64-1.055l-.822-1.316a2.192 2.192 0 0 0-1.736-1.039 48.774 48.774 0 0 0-5.232 0 2.192 2.192 0 0 0-1.736 1.039l-.821 1.316Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 1 1-9 0 4.5 4.5 0 0 1 9 0ZM18.75 10.5h.008v.008h-.008V10.5Z" /></svg>
                    Take Photo
                </button>
                
                <div class="scanner-divider">
                    <span>or</span>
                </div>

                <label class="action secondary scanner-upload" for="scanner-photo-input">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 1.25rem; height: 1.25rem; margin-right: 0.5rem;"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" /></svg>
                    Upload from gallery
                </label>
                <InputFile id="scanner-photo-input" 
                           style="display: none;"
                           OnChange="HandlePhotoSelectedAsync" 
                           accept="image/*" 
                           disabled="@_isScanning" />
            </div>
        }
        else
        {
            <div class="scanner-preview-wrap">
                <img src="@_photoPreviewUrl"
                     alt="Selected fish photo preview"
                     class="scanner-preview-image" />
                <button type="button" class="scanner-clear-btn" @onclick="ClearPhoto" disabled="@_isScanning">
                    ✖ Clear
                </button>
            </div>
        }

        <div class="scanner-auto-measure-toggle">
            <label class="scanner-checkbox-label">
                <input type="checkbox" @bind="_autoMeasureEnabled" disabled="@_isScanning" />
                <span>Auto-measure fish length</span>
            </label>
            @if (_autoMeasureEnabled && !_isCalibrated)
            {
                <p class="scanner-info-text scanner-warning">⚠️ Camera not calibrated. Use calibration mode first for accurate measurements.</p>
            }
            else if (_autoMeasureEnabled && _useSensorMode)
            {
                <p class="scanner-info-text">Using sensor-based measurement. Estimate the distance from camera to fish.</p>
            }
            else if (_autoMeasureEnabled)
            {
                <p class="scanner-info-text">Using reference object. Place a ruler or known-size object (e.g., 10cm = 0.1m) next to the fish.</p>
            }
        </div>

        @if (_autoMeasureEnabled && !_isCalibrated)
        {
            <div class="scanner-calibration-prompt">
                <h3>📏 Calibrate Camera (One-time Setup)</h3>
                <p>To use sensor-based measurement, calibrate your camera once:</p>
                <ol class="scanner-calibration-steps">
                    <li>Find a standard ruler or measuring tape (20cm section)</li>
                    <li>Hold it at arm's length (~0.5m away) and take a photo</li>
                    <li>Upload the photo and click "Start Calibration"</li>
                    <li>The app will calculate your camera's focal length</li>
                </ol>
                @if (_selectedPhoto is null)
                {
                    <p class="scanner-calibration-warning">⬆️ Please upload a calibration photo first</p>
                }
                <button class="action secondary" type="button" @onclick="StartCalibration" disabled="@(_isCalibrating || _selectedPhoto is null)">
                    @(_isCalibrating ? "Calibrating..." : "Start Calibration")
                </button>
            </div>
        }

        @if (_autoMeasureEnabled && _detectedBoundingBox != null)
        {
            <div class="scanner-ar-result">
                <div class="scanner-ar-badge">✓ Fish detected</div>
                <p class="scanner-ar-info">Bounding box: [@_detectedBoundingBox.Y0, @_detectedBoundingBox.X0] → [@_detectedBoundingBox.Y1, @_detectedBoundingBox.X1]</p>
            </div>
        }

        @if (_autoMeasureEnabled && _isCalibrated)
        {
            <label class="scanner-field-label" for="distance-input">Distance from camera to fish (meters)</label>
            <input id="distance-input"
                   class="scanner-input"
                   inputmode="decimal"
                   placeholder="e.g. 0.5 (arm's length)"
                   value="@_assumedDistanceText"
                   @oninput="OnDistanceChanged"
                   disabled="@_isScanning || _isAutoMeasuring" />
        }
        else if (_autoMeasureEnabled && !_isCalibrated)
        {
            <label class="scanner-field-label" for="reference-size-input">Reference object size (meters)</label>
            <input id="reference-size-input"
                   class="scanner-input"
                   inputmode="decimal"
                   placeholder="e.g. 0.1 (10cm ruler)"
                   value="@_referenceObjectSizeText"
                   @oninput="OnReferenceSizeChanged"
                   disabled="@_isScanning" />
        }

        <label class="scanner-field-label" for="fish-length-input">Fish length (meters)</label>
        <input id="fish-length-input"
               class="scanner-input"
               inputmode="decimal"
               placeholder="e.g. 0.74"
               value="@_lengthInputText"
               @oninput="OnLengthChanged"
               readonly="@(_autoMeasureEnabled && _isAutoMeasuring)" />

        <button class="action primary scanner-submit"
                type="button"
                disabled="@(!_canScan || _isScanning)"
                @onclick="ScanAndLogAsync">
            @(_isScanning ? "Scanning…" : "Scan & Log Catch")
        </button>

        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <p class="scanner-status">@_statusMessage</p>
        }

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <p class="scanner-error">@_errorMessage</p>
        }

        @if (!string.IsNullOrWhiteSpace(_speciesName))
        {
            <div class="scanner-result-head">@_speciesName</div>
        }

        @if (!string.IsNullOrWhiteSpace(_generatedFishImageUrl))
        {
            <div class="scanner-image-wrap">
                <img src="@_generatedFishImageUrl"
                     alt="Generated illustration of @_speciesName"
                     class="scanner-image" />
            </div>
        }
    </section>

    <section class="scanner-actions-row">
        <button class="action secondary" type="button" @onclick="GoToFishDex">Open FishDex</button>
    </section>

    <BottomNav />
</div>

@if (_showGlobalDiscoveryPopup)
{
    <div class="scanner-popup-overlay" @onclick="CloseGlobalDiscoveryPopup">
        <div class="ocean-glass scanner-popup" @onclick:stopPropagation="true">
            <h2>New global species discovered</h2>
            <p>@_speciesName has been added to the community FishDex.</p>
            @if (!string.IsNullOrWhiteSpace(_environmentalImpactMessage))
            {
                <p class="scanner-environmental-msg"><strong>Impact:</strong> @_environmentalImpactMessage</p>
            }
            <button class="action primary" type="button" @onclick="CloseGlobalDiscoveryPopup">Awesome</button>
        </div>
    </div>
}

@if (_showUnlockPopup)
{
    <div class="scanner-popup-overlay" @onclick="CloseUnlockPopup">
        <div class="ocean-glass scanner-popup" @onclick:stopPropagation="true">
            <h2>New FishDex unlock</h2>
            <p>You caught @_speciesName for the first time and unlocked it in your FishDex.</p>
            @if (!string.IsNullOrWhiteSpace(_environmentalImpactMessage))
            {
                <p class="scanner-environmental-msg"><strong>Impact:</strong> @_environmentalImpactMessage</p>
            }
            <button class="action primary" type="button" @onclick="CloseUnlockPopup">Nice</button>
        </div>
    </div>
}

@if (_showPersonalBestPopup)
{
    <div class="scanner-popup-overlay" @onclick="ClosePersonalBestPopup">
        <div class="ocean-glass scanner-popup" @onclick:stopPropagation="true">
            <h2>Personal best</h2>
            <p>That's your biggest @_speciesName yet.</p>
            @if (!string.IsNullOrWhiteSpace(_environmentalImpactMessage))
            {
                <p class="scanner-environmental-msg"><strong>Impact:</strong> @_environmentalImpactMessage</p>
            }
            <button class="action primary" type="button" @onclick="ClosePersonalBestPopup">Keep fishing</button>
        </div>
    </div>
}

@if (_showEnvironmentalPopup)
{
    <div class="scanner-popup-overlay" @onclick="CloseEnvironmentalPopup">
        <div class="ocean-glass scanner-popup" @onclick:stopPropagation="true">
            <h2>Environmental Impact</h2>
            <p>@_environmentalImpactMessage</p>
            <button class="action primary" type="button" @onclick="CloseEnvironmentalPopup">Got it</button>
        </div>
    </div>
}

@code {
    private const long MaxPhotoSizeBytes = 10 * 1024 * 1024;

    private byte[]? _photoBytes;
    private string? _photoMimeType;
    private string? _photoPreviewUrl;
    private bool _isScanning;
    private string? _speciesName;
    private string? _generatedFishImageUrl;
    private string? _statusMessage;
    private string? _errorMessage;
    private string _lengthInputText = string.Empty;
    private bool _canScan;
    private bool _showGlobalDiscoveryPopup;
    private bool _showUnlockPopup;
    private bool _showPersonalBestPopup;
    private bool _showEnvironmentalPopup;
    private string? _environmentalImpactMessage;
    private bool _autoMeasureEnabled;
    private bool _isAutoMeasuring;
    private bool _isCalibrated;
    private bool _useSensorMode = true;
    private bool _isCalibrating;
    private FishBoundingBoxDto? _detectedBoundingBox;
    private string _referenceObjectSizeText = "0.1";
    private string _assumedDistanceText = "0.5";
    private byte[]? _photoBytes;

    private async Task HandlePhotoSelectedAsync(InputFileChangeEventArgs eventArgs)
    {
        var selectedFile = eventArgs.File;
        if (selectedFile is null)
        {
            _statusMessage = "No photo selected.";
            return;
        }

        try
        {
            await using var stream = selectedFile.OpenReadStream(MaxPhotoSizeBytes);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);

            if (memoryStream.Length == 0)
            {
                _errorMessage = "No photo data was found.";
                _statusMessage = null;
                return;
            }

            var mimeType = string.IsNullOrWhiteSpace(selectedFile.ContentType)
                ? "image/jpeg"
                : selectedFile.ContentType;

            SetSelectedPhoto(memoryStream.ToArray(), mimeType, "Photo uploaded. Ready to scan your catch.");
        }
        catch (IOException)
        {
            _errorMessage = "Photo must be smaller than 10 MB.";
            _statusMessage = null;
        }
    }

    private async Task CapturePhotoAsync()
    {
        if (_isScanning)
        {
            return;
        }

        _errorMessage = null;
        _statusMessage = "Opening camera...";

        try
        {
            var capturedPhoto = await PhotoCaptureService.CapturePhotoAsync();

            if (capturedPhoto is null)
            {
                _statusMessage = "Camera capture canceled.";
                return;
            }

            if (capturedPhoto.Bytes.Length == 0)
            {
                _errorMessage = "No photo data was found.";
                _statusMessage = null;
                return;
            }

            if (capturedPhoto.Bytes.Length > MaxPhotoSizeBytes)
            {
                _errorMessage = "Photo must be smaller than 10 MB.";
                _statusMessage = null;
                return;
            }

            SetSelectedPhoto(capturedPhoto.Bytes, capturedPhoto.MimeType, "Photo captured. Ready to scan your catch.");
        }
        catch (OperationCanceledException)
        {
            _statusMessage = "Camera capture canceled.";
        }
        catch (Exception ex)
        {
            _errorMessage = string.IsNullOrWhiteSpace(ex.Message)
                ? "Unable to capture a photo from the camera."
                : ex.Message;
            _statusMessage = null;
        }
    }

    private void SetSelectedPhoto(byte[] photoBytes, string mimeType, string readyMessage)
    {
        _photoBytes = photoBytes;
        _photoMimeType = string.IsNullOrWhiteSpace(mimeType) ? "image/jpeg" : mimeType;
        _photoPreviewUrl = $"data:{_photoMimeType};base64,{Convert.ToBase64String(_photoBytes)}";
        _canScan = true;
        _errorMessage = null;
        _detectedBoundingBox = null;
        _statusMessage = readyMessage;
        _speciesName = null;
        _generatedFishImageUrl = null;
        _showGlobalDiscoveryPopup = false;
        _showUnlockPopup = false;
        _showPersonalBestPopup = false;
        _showEnvironmentalPopup = false;
        _environmentalImpactMessage = null;

		if (_autoMeasureEnabled && _selectedPhoto is not null)
        {
            await AutoMeasureFishLengthAsync();
        }
    }

    private void ClearPhoto()
    {
        _photoBytes = null;
        _photoMimeType = null;
        _photoPreviewUrl = null;
        _canScan = false;
        _errorMessage = null;
        _statusMessage = null;
        _speciesName = null;
        _generatedFishImageUrl = null;
    }

    private void OnLengthChanged(ChangeEventArgs eventArgs)
    {
        _lengthInputText = eventArgs.Value?.ToString() ?? string.Empty;
    }

    private void OnReferenceSizeChanged(ChangeEventArgs eventArgs)
    {
        _referenceObjectSizeText = eventArgs.Value?.ToString() ?? string.Empty;
    }

    private void OnDistanceChanged(ChangeEventArgs eventArgs)
    {
        _assumedDistanceText = eventArgs.Value?.ToString() ?? string.Empty;
    }

    protected override async Task OnInitializedAsync()
    {
        _isCalibrated = await CalibrationService.IsCalibrated();
    }

    private async Task StartCalibration()
    {
        if (_selectedPhoto is null)
        {
            _errorMessage = "Please upload a calibration photo first (e.g., credit card at arm's length).";
            return;
        }

        _isCalibrating = true;
        _errorMessage = null;

        try
        {
            var mimeType = string.IsNullOrWhiteSpace(_selectedPhoto.ContentType)
                ? "image/jpeg"
                : _selectedPhoto.ContentType;

            await using var stream = _selectedPhoto.OpenReadStream(MaxPhotoSizeBytes);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            _photoBytes = memoryStream.ToArray();

            if (_photoBytes.Length == 0)
            {
                _errorMessage = "No photo data was found.";
                return;
            }

            // Detect reference object (ruler) in the image
            _detectedBoundingBox = await GeminiService.DetectFishBoundingBoxAsync(_photoBytes, mimeType);

            if (_detectedBoundingBox is null)
            {
                _errorMessage = "Could not detect object in calibration image. Please try again.";
                return;
            }

            // Calculate the object width in pixels
            var objectWidthNormalized = _detectedBoundingBox.X1 - _detectedBoundingBox.X0;
            var objectWidthPixels = (int)((objectWidthNormalized / 1000.0) * _detectedBoundingBox.ImageWidth);

            // Assume 20cm ruler section at 0.5m distance
            var knownDistance = 0.5; // meters (arm's length)
            var realWidth = 0.2; // meters (20cm ruler section)

            var focalLength = CalibrationService.CalculateFocalLength(objectWidthPixels, knownDistance, realWidth);

            await CalibrationService.SaveCalibrationAsync(focalLength, knownDistance);

            _isCalibrated = true;
            _statusMessage = $"✅ Camera calibrated! Focal length: {focalLength:F0} pixels";
            _useSensorMode = true;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Calibration failed: {ex.Message}";
        }
        finally
        {
            _isCalibrating = false;
        }
    }

    private async Task AutoMeasureFishLengthAsync()
    {
        if (_selectedPhoto is null || _isAutoMeasuring)
        {
            return;
        }

        _isAutoMeasuring = true;
        _statusMessage = "Detecting fish in image...";
        _errorMessage = null;

        try
        {
            var mimeType = string.IsNullOrWhiteSpace(_selectedPhoto.ContentType)
                ? "image/jpeg"
                : _selectedPhoto.ContentType;

            await using var stream = _selectedPhoto.OpenReadStream(MaxPhotoSizeBytes);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            _photoBytes = memoryStream.ToArray();

            if (_photoBytes.Length == 0)
            {
                _errorMessage = "No photo data was found.";
                _statusMessage = null;
                return;
            }

            // Detect fish bounding box
            _detectedBoundingBox = await GeminiService.DetectFishBoundingBoxAsync(_photoBytes, mimeType);

            if (_detectedBoundingBox is null)
            {
                _errorMessage = "Could not detect a fish in the image. Please try a different photo.";
                _statusMessage = null;
                return;
            }

            // Calculate fish length from bounding box
            double fishLength;

            if (_isCalibrated && _useSensorMode)
            {
                // Use sensor-based measurement with calibrated focal length
                if (double.TryParse(_assumedDistanceText, CultureInfo.InvariantCulture, out var distance) && distance > 0)
                {
                    fishLength = await MeasurementService.CalculateFishLengthFromCameraAsync(_detectedBoundingBox, distance);
                    _lengthInputText = fishLength.ToString("F2", CultureInfo.InvariantCulture);
                    _statusMessage = $"Fish detected! Estimated length: {fishLength:F2}m (sensor-based)";
                }
                else
                {
                    _statusMessage = "Fish detected! Please enter a valid distance estimate.";
                }
            }
            else
            {
                // Use reference object-based measurement
                if (double.TryParse(_referenceObjectSizeText, CultureInfo.InvariantCulture, out var referenceSize) && referenceSize > 0)
                {
                    fishLength = MeasurementService.CalculateFishLengthFromBoundingBox(_detectedBoundingBox, referenceSize);
                    _lengthInputText = fishLength.ToString("F2", CultureInfo.InvariantCulture);
                    _statusMessage = $"Fish detected! Estimated length: {fishLength:F2}m (reference-based)";
                }
                else
                {
                    _statusMessage = "Fish detected! Please enter a valid reference object size.";
                }
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Auto-measure failed: {ex.Message}";
            _statusMessage = null;
        }
        finally
        {
            _isAutoMeasuring = false;
        }
    }

    private async Task ScanAndLogAsync()
    {
        if (_isScanning || _photoBytes is null)
        {
            return;
        }

        _isScanning = true;
        _speciesName = null;
        _generatedFishImageUrl = null;
        _showGlobalDiscoveryPopup = false;
        _showUnlockPopup = false;
        _showPersonalBestPopup = false;
        _showEnvironmentalPopup = false;
        _statusMessage = "Scanning fish species...";
        _errorMessage = null;

        try
        {
            var mimeType = string.IsNullOrWhiteSpace(_selectedPhoto.ContentType)
                ? "image/jpeg"
                : _selectedPhoto.ContentType;

            byte[] photoBytes;

            // Reuse photo bytes if already loaded from auto-measure
            if (_photoBytes is not null && _photoBytes.Length > 0)
            {
                photoBytes = _photoBytes;
            }
            else
            {
                await using var stream = _selectedPhoto.OpenReadStream(MaxPhotoSizeBytes);
                using var memoryStream = new MemoryStream();
                await stream.CopyToAsync(memoryStream);
                photoBytes = memoryStream.ToArray();
            }

            if (photoBytes.Length == 0)
            {
                _errorMessage = "No photo data was found.";
                _statusMessage = null;
                return;
            }

            var location = await LocationService.GetCurrentLocationAsync();
            var locationJson = location != null 
                ? System.Text.Json.JsonSerializer.Serialize(new { lat = location.Latitude, lon = location.Longitude, desc = location.Description })
                : null;

            var currentUser = await SocialService.ResolveCurrentUserAsync();
            var scanRequest = new FishScanLogRequestDto(
                _photoBytes,
                _photoMimeType ?? "image/jpeg",
                ParseLengthMeters(),
                null,
                null,
                locationJson);

            var scanResult = await FishDexService.ScanAndLogCatchAsync(currentUser.Id, scanRequest);
            _speciesName = scanResult.SpeciesName;
            _generatedFishImageUrl = scanResult.SpeciesImageUrl;
            _statusMessage = "Catch logged and FishDex updated.";

            _showGlobalDiscoveryPopup = scanResult.IsNewGlobalSpecies;
            _showUnlockPopup = scanResult.IsFirstCatchForUser && !scanResult.IsNewGlobalSpecies;
            _showPersonalBestPopup = !scanResult.IsFirstCatchForUser && scanResult.IsNewPersonalBest;

            if (scanResult.WasImageGenerated)
            {
                _statusMessage = "Catch logged, FishDex updated, and a new species image was generated.";
            }

            try 
            {
                _environmentalImpactMessage = await GeminiService.GetEnvironmentalImpactAsync(_speciesName, scanRequest.LengthMeters, locationJson);
                if (!string.IsNullOrWhiteSpace(_environmentalImpactMessage))
                {
                    if (!_showGlobalDiscoveryPopup && !_showUnlockPopup && !_showPersonalBestPopup)
                    {
                        _showEnvironmentalPopup = true;
                    }
                }
            } 
            catch (InvalidOperationException ex)
            {
                Console.WriteLine($"Error getting environmental impact: {ex.Message}");
            }
            catch (HttpRequestException ex)
            {
                Console.WriteLine($"Error getting environmental impact: {ex.Message}");
            }
            catch (System.Text.Json.JsonException ex)
            {
                // In case getting environmental impact fails, we shouldn't fail the whole catch process.
                Console.WriteLine($"Error getting environmental impact: {ex.Message}");
            }
        }
        catch (OperationCanceledException)
        {
            _errorMessage = "Photo processing was canceled.";
            _statusMessage = null;
        }
        catch (InvalidOperationException ex)
        {
            _errorMessage = ex.Message;
            _statusMessage = null;
        }
        catch (HttpRequestException ex)
        {
            _errorMessage = string.IsNullOrWhiteSpace(ex.Message)
                ? "Network request failed while generating the image."
                : ex.Message;
            _statusMessage = null;
        }
        catch (System.Text.Json.JsonException ex)
        {
            _errorMessage = string.IsNullOrWhiteSpace(ex.Message)
                ? "Invalid response was returned by the image service."
                : ex.Message;
            _statusMessage = null;
        }
        finally
        {
            _isScanning = false;
        }
    }

    private double? ParseLengthMeters()
    {
        if (string.IsNullOrWhiteSpace(_lengthInputText))
        {
            return null;
        }

        if (double.TryParse(_lengthInputText, CultureInfo.InvariantCulture, out var lengthMeters) && lengthMeters > 0)
        {
            return lengthMeters;
        }

        throw new InvalidOperationException("Fish length must be a positive number in meters.");
    }

    private void GoToFishDex()
    {
        NavigationManager.NavigateTo("/fishdex");
    }

    private void CloseGlobalDiscoveryPopup()
    {
        _showGlobalDiscoveryPopup = false;
    }

    private void CloseUnlockPopup()
    {
        _showUnlockPopup = false;
    }

    private void ClosePersonalBestPopup()
    {
        _showPersonalBestPopup = false;
    }

    private void CloseEnvironmentalPopup()
    {
        _showEnvironmentalPopup = false;
    }
}
