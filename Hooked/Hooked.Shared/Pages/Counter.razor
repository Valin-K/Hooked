@page "/counter"
@using Hooked.Shared.Services
@inject ICatchService CatchService

<PageTitle>Activity</PageTitle>

<div class="card">
    <div class="card-row">
        <div>
            <div class="title">Quick Stats</div>
            <div class="muted">Overview of your recent activity</div>
        </div>
        <div style="margin-left:auto;text-align:right">
            <div style="font-weight:700;font-size:1.25rem">@totalCatches</div>
            <div class="muted">Total catches</div>
        </div>
    </div>

    <hr />

    <div class="card-row" style="margin-top:12px">
        <div class="card" style="flex:1">
            <div class="title">Biggest</div>
            <div class="muted">Coming soon</div>
        </div>
        <div class="card" style="flex:1">
            <div class="title">Rarest</div>
            <div class="muted">Coming soon</div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(loadErrorMessage))
    {
        <div class="muted" style="margin-top:12px">@loadErrorMessage</div>
    }
</div>

@code{
    private int totalCatches = 0;
    private string? loadErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var items = await CatchService.GetRecentCatchesAsync(100);
            totalCatches = items?.Count() ?? 0;
        }
        catch (Exception)
        {
            totalCatches = 0;
            loadErrorMessage = "Could not load activity right now.";
        }
    }
}
