@page "/feed"
@using Hooked.Shared.Services
@inject ISocialService SocialService

<PageTitle>Community Feed</PageTitle>

<div class="mobile-shell feed-shell">
    <header class="feed-header ocean-glass">
        <div>
            <div class="feed-kicker">Community</div>
            <h1>Catch Feed</h1>
        </div>
        <div class="feed-current-user">@($"@{_currentUsername}")</div>
    </header>

    @if (_isLoading)
    {
        <section class="feed-state ocean-glass">Loading community catches…</section>
    }
    else if (_loadError is not null)
    {
        <section class="feed-state ocean-glass error">@_loadError</section>
    }
    else if (_feedItems.Count == 0)
    {
        <section class="feed-state ocean-glass">No community catches yet. Check back soon.</section>
    }
    else
    {
        @if (_actionError is not null)
        {
            <section class="feed-alert ocean-glass">@_actionError</section>
        }

        <section class="feed-list">
            @foreach (var item in _feedItems)
            {
                var isSelf = item.UserId == _currentUserId;
                var isFollowing = IsFollowing(item.UserId);
                var reactionBusy = _reactionBusyCatchIds.Contains(item.CatchId);
                var commentBusy = _commentBusyCatchIds.Contains(item.CatchId);
                var followBusy = _followBusyUserIds.Contains(item.UserId);

                <article class="feed-card ocean-glass">
                    <header class="card-header">
                        <a class="author-link" href="@BuildProfileLink(item.Username)">
                            <div class="author-avatar">@GetAvatarToken(item.DisplayName, item.Username)</div>
                            <div>
                                <div class="author-name">@GetDisplayName(item.DisplayName, item.Username)</div>
                                <div class="author-handle">@($"@{item.Username}")</div>
                            </div>
                        </a>

                        @if (!isSelf)
                        {
                            <button class="follow-btn"
                                    type="button"
                                    disabled="@followBusy"
                                    @onclick="() => ToggleFollowAsync(item)">
                                @(isFollowing ? "Following" : "Follow")
                            </button>
                        }
                    </header>

                    <div class="catch-main">
                        <div class="catch-copy">
                            <h2>@item.SpeciesCommonName</h2>
                            <div class="catch-time">@item.CaughtAt.ToLocalTime().ToString("MMM d, yyyy • h:mm tt")</div>
                            @if (TryFormatMeasurements(item, out var measurements))
                            {
                                <div class="catch-metrics">@measurements</div>
                            }
                        </div>
                        <div class="catch-photo @(item.HasPhoto ? "has-photo" : string.Empty)">
                            @(item.HasPhoto ? "◉" : "◌")
                        </div>
                    </div>

                    <div class="interaction-row">
                        <button class="reaction-btn"
                                type="button"
                                disabled="@reactionBusy"
                                @onclick="() => ToggleReactionAsync(item)">
                            <span>@(item.ViewerHasReacted ? "♥" : "♡")</span>
                            <span>@item.ReactionCount</span>
                        </button>
                        <div class="comment-count">@($"{item.CommentCount} comments")</div>
                    </div>

                    <section class="comments-block">
                        <div class="comments-title">Recent comments</div>
                        @if (item.RecentComments.Count == 0)
                        {
                            <div class="comment-empty">No comments yet.</div>
                        }
                        else
                        {
                            @foreach (var comment in item.RecentComments)
                            {
                                <div class="comment-row">
                                    <a href="@BuildProfileLink(comment.Username)" class="comment-author">@($"@{comment.Username}")</a>
                                    <span class="comment-text">@comment.CommentText</span>
                                </div>
                            }
                        }
                    </section>

                    <div class="comment-form">
                        <input class="comment-input"
                               maxlength="500"
                               placeholder="Add a comment…"
                               value="@GetCommentDraft(item.CatchId)"
                               @oninput="e => SetCommentDraft(item.CatchId, e.Value?.ToString() ?? string.Empty)" />
                        <button class="comment-submit"
                                type="button"
                                disabled="@commentBusy || string.IsNullOrWhiteSpace(GetCommentDraft(item.CatchId))"
                                @onclick="() => SubmitCommentAsync(item)">
                            Post
                        </button>
                    </div>
                </article>
            }
        </section>
    }

    <bottom-nav />
</div>

@code {
    private readonly List<FeedCardModel> _feedItems = [];
    private readonly Dictionary<Guid, bool> _followStateByUserId = [];
    private readonly Dictionary<Guid, string> _commentDraftsByCatchId = [];
    private readonly HashSet<Guid> _reactionBusyCatchIds = [];
    private readonly HashSet<Guid> _commentBusyCatchIds = [];
    private readonly HashSet<Guid> _followBusyUserIds = [];

    private Guid _currentUserId = Guid.Empty;
    private string _currentUsername = "guest";
    private bool _isLoading = true;
    private string? _loadError;
    private string? _actionError;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var currentUser = await SocialService.ResolveCurrentUserAsync();
            _currentUserId = currentUser.Id;
            _currentUsername = currentUser.Username;

            var feedItems = await SocialService.GetCommunityFeedAsync(_currentUserId);
            _feedItems.Clear();
            _feedItems.AddRange(feedItems.Select(FeedCardModel.FromDto));

            foreach (var item in _feedItems)
            {
                _commentDraftsByCatchId[item.CatchId] = string.Empty;
            }

            var authorIds = _feedItems
                .Select(item => item.UserId)
                .Distinct()
                .Where(userId => userId != _currentUserId)
                .ToArray();

            if (authorIds.Length > 0)
            {
                var summaryTasks = authorIds.Select(async authorId => new
                {
                    AuthorId = authorId,
                    Summary = await SocialService.GetProfileSummaryByIdAsync(authorId, _currentUserId)
                });

                var summaries = await Task.WhenAll(summaryTasks);
                foreach (var summary in summaries)
                {
                    _followStateByUserId[summary.AuthorId] = summary.Summary?.IsFollowing ?? false;
                }
            }
        }
        catch (Exception ex)
        {
            _loadError = $"Unable to load feed: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private bool IsFollowing(Guid authorUserId)
    {
        return _followStateByUserId.TryGetValue(authorUserId, out var isFollowing) && isFollowing;
    }

    private async Task ToggleFollowAsync(FeedCardModel item)
    {
        if (_currentUserId == Guid.Empty || item.UserId == _currentUserId || _followBusyUserIds.Contains(item.UserId))
        {
            return;
        }

        _actionError = null;
        _followBusyUserIds.Add(item.UserId);

        try
        {
            var currentlyFollowing = IsFollowing(item.UserId);
            if (currentlyFollowing)
            {
                await SocialService.UnfollowAsync(_currentUserId, item.UserId);
            }
            else
            {
                await SocialService.FollowAsync(_currentUserId, item.UserId);
            }

            _followStateByUserId[item.UserId] = !currentlyFollowing;
        }
        catch (Exception ex)
        {
            _actionError = $"Follow action failed: {ex.Message}";
        }
        finally
        {
            _followBusyUserIds.Remove(item.UserId);
        }
    }

    private async Task ToggleReactionAsync(FeedCardModel item)
    {
        if (_currentUserId == Guid.Empty || _reactionBusyCatchIds.Contains(item.CatchId))
        {
            return;
        }

        _actionError = null;
        _reactionBusyCatchIds.Add(item.CatchId);

        try
        {
            var result = await SocialService.ToggleReactionAsync(item.CatchId, _currentUserId);
            item.ViewerHasReacted = result.IsReacted;
            item.ReactionCount = result.ReactionCount;
        }
        catch (Exception ex)
        {
            _actionError = $"Reaction failed: {ex.Message}";
        }
        finally
        {
            _reactionBusyCatchIds.Remove(item.CatchId);
        }
    }

    private async Task SubmitCommentAsync(FeedCardModel item)
    {
        if (_currentUserId == Guid.Empty || _commentBusyCatchIds.Contains(item.CatchId))
        {
            return;
        }

        var text = GetCommentDraft(item.CatchId).Trim();
        if (text.Length == 0)
        {
            return;
        }

        _actionError = null;
        _commentBusyCatchIds.Add(item.CatchId);

        try
        {
            var comment = await SocialService.AddCommentAsync(item.CatchId, _currentUserId, text);
            item.CommentCount += 1;
            item.RecentComments.Add(comment);
            item.RecentComments = item.RecentComments
                .OrderBy(c => c.CommentedAt)
                .TakeLast(3)
                .ToList();
            _commentDraftsByCatchId[item.CatchId] = string.Empty;
        }
        catch (Exception ex)
        {
            _actionError = $"Comment failed: {ex.Message}";
        }
        finally
        {
            _commentBusyCatchIds.Remove(item.CatchId);
        }
    }

    private string GetCommentDraft(Guid catchId)
    {
        return _commentDraftsByCatchId.TryGetValue(catchId, out var draft) ? draft : string.Empty;
    }

    private void SetCommentDraft(Guid catchId, string value)
    {
        _commentDraftsByCatchId[catchId] = value;
    }

    private static string BuildProfileLink(string username)
    {
        return $"/profile/{Uri.EscapeDataString(username)}";
    }

    private static string GetDisplayName(string? displayName, string username)
    {
        return string.IsNullOrWhiteSpace(displayName) ? username : displayName;
    }

    private static string GetAvatarToken(string? displayName, string username)
    {
        var source = string.IsNullOrWhiteSpace(displayName) ? username : displayName;
        if (string.IsNullOrWhiteSpace(source))
        {
            return "◌";
        }

        return source.Trim()[0].ToString().ToUpperInvariant();
    }

    private static bool TryFormatMeasurements(FeedCardModel item, out string measurements)
    {
        var parts = new List<string>(2);
        if (item.LengthMeters.HasValue)
        {
            parts.Add($"{item.LengthMeters.Value:F2} m");
        }

        if (item.WeightKg.HasValue)
        {
            parts.Add($"{item.WeightKg.Value:F2} kg");
        }

        measurements = string.Join(" • ", parts);
        return parts.Count > 0;
    }

    private sealed class FeedCardModel
    {
        public Guid CatchId { get; init; }
        public Guid UserId { get; init; }
        public string Username { get; init; } = string.Empty;
        public string? DisplayName { get; init; }
        public DateTime CaughtAt { get; init; }
        public string SpeciesCommonName { get; init; } = string.Empty;
        public double? LengthMeters { get; init; }
        public double? WeightKg { get; init; }
        public bool HasPhoto { get; init; }
        public int ReactionCount { get; set; }
        public int CommentCount { get; set; }
        public bool ViewerHasReacted { get; set; }
        public List<SocialCommentDto> RecentComments { get; set; } = [];

        public static FeedCardModel FromDto(SocialCatchFeedItemDto dto)
        {
            return new FeedCardModel
            {
                CatchId = dto.CatchId,
                UserId = dto.UserId,
                Username = dto.Username,
                DisplayName = dto.DisplayName,
                CaughtAt = dto.CaughtAt,
                SpeciesCommonName = dto.SpeciesCommonName,
                LengthMeters = dto.LengthMeters,
                WeightKg = dto.WeightKg,
                HasPhoto = !string.IsNullOrWhiteSpace(dto.PhotoPath),
                ReactionCount = dto.ReactionCount,
                CommentCount = dto.CommentCount,
                ViewerHasReacted = dto.ViewerHasReacted,
                RecentComments = dto.RecentComments
                    .OrderBy(c => c.CommentedAt)
                    .ToList()
            };
        }
    }
}
