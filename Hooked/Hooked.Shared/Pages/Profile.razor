@page "/profile"
@page "/profile/{Username}"
@using Hooked.Shared.Data
@using Hooked.Shared.Services
@inject ISocialService SocialService
@inject IAchievementService AchievementService
@inject ICatchService CatchService
@inject IProgressionService ProgressionService
@inject IFishingQuestService FishingQuestService
@inject NavigationManager NavigationManager

<PageTitle>@GetPageTitle()</PageTitle>

<div class="mobile-shell profile-shell">
    @if (_isLoading)
    {
        <section class="ocean-glass state-card">
            <p class="muted">Loading profile…</p>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(_loadError))
    {
        <section class="ocean-glass state-card">
            <h1>Profile unavailable</h1>
            <p class="muted">@_loadError</p>
            <button class="action secondary" type="button" @onclick="ReloadAsync">Retry</button>
        </section>
    }
    else if (_profile is null || _currentUser is null)
    {
        <section class="ocean-glass state-card">
            <h1>Profile not found</h1>
            <p class="muted">We couldn't find this angler.</p>
            <button class="action secondary" type="button" @onclick="GoHome">Back to feed</button>
        </section>
    }
    else
    {
        <section class="ocean-glass profile-summary">
            <div class="summary-top">
                <div class="profile-avatar" aria-hidden="true">
                    <AppIcon Name="user-circle" Size="22" />
                </div>
                <div class="identity">
                    <h1>@DisplayNameFor(_profile.DisplayName, _profile.Username)</h1>
                    <div class="handle">@("@"+_profile.Username)</div>
                    <div class="joined">Joined @_profile.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")</div>
                </div>
            </div>
            <div class="stats-grid profile-stats-grid">
                <article class="stat-card ocean-glass">
                    <div class="stat-label">Catches</div>
                    <div class="stat-value">@_profile.CatchCount</div>
                </article>
                <article class="stat-card ocean-glass">
                    <div class="stat-label">Followers</div>
                    <div class="stat-value">@_profile.FollowerCount</div>
                </article>
                <article class="stat-card ocean-glass">
                    <div class="stat-label">Following</div>
                    <div class="stat-value">@_profile.FollowingCount</div>
                </article>
            </div>

            @if (IsViewingOtherUser)
            {
                <button class="action @( _profile.IsFollowing ? "secondary" : "primary" ) follow-action"
                        type="button"
                        disabled="@_isFollowBusy"
                        @onclick="ToggleFollowAsync">
                    @(_profile.IsFollowing ? "Unfollow" : "Follow")
                </button>
            }
        </section>

        @if (!IsViewingOtherUser)
        {
            <section class="profile-progression">
                @if (_isProgressionLoading)
                {
                    <article class="ocean-glass progression-card">
                        <p class="muted">Loading progression…</p>
                    </article>
                }
                else if (!string.IsNullOrWhiteSpace(_progressionError))
                {
                    <article class="ocean-glass progression-card">
                        <h2>Progression unavailable</h2>
                        <p class="muted">@_progressionError</p>
                        <button class="action secondary" type="button" @onclick="ReloadProgressionAsync">Retry progression</button>
                    </article>
                }
                else if (_progressionOverview is not null)
                {
                    <article class="ocean-glass progression-card">
                        <header class="progression-heading">
                            <h2>Overall XP</h2>
                            <span class="xp-total">@_progressionOverview.OverallTotalXpEarned XP</span>
                        </header>

                        <p class="muted progression-subtitle">@_progressionOverview.PrimarySkillName · Level @_progressionOverview.CurrentLevel</p>

                        <div class="xp-progress">
                            <div class="xp-progress-track">
                                <div class="xp-progress-fill" style="width: @GetXpProgressPercent(_progressionOverview)%"></div>
                            </div>
                            <div class="xp-progress-label">@GetXpProgressLabel(_progressionOverview)</div>
                        </div>
                    </article>

                    <article class="ocean-glass quest-board">
                        <header class="quest-board-heading">
                            <h2>Quests</h2>
                            <span class="muted">@_activeQuests.Count total</span>
                        </header>

                        <div class="quest-cadence-groups">
                            @foreach (var cadence in QuestCadenceDisplayOrder)
                            {
                                var cadenceQuests = GetQuestsByCadence(cadence);
                                <section class="quest-cadence-group">
                                    <h3>@GetCadenceLabel(cadence)</h3>

                                    @if (cadenceQuests.Count == 0)
                                    {
                                        <p class="muted cadence-empty">No @(GetCadenceLabel(cadence).ToLowerInvariant()) quests right now.</p>
                                    }
                                    else
                                    {
                                        @foreach (var quest in cadenceQuests)
                                        {
                                            <article class="quest-item">
                                                <div class="quest-item-head">
                                                    <div>
                                                        <h4>@quest.QuestName</h4>
                                                        @if (!string.IsNullOrWhiteSpace(quest.QuestDescription))
                                                        {
                                                            <p class="muted quest-description">@quest.QuestDescription</p>
                                                        }
                                                    </div>
                                                    <span class="quest-reward">+@quest.RewardXp XP</span>
                                                </div>

                                                <div class="quest-progress">
                                                    <div class="quest-progress-track">
                                                        <div class="quest-progress-fill" style="width: @GetQuestProgressPercent(quest)%"></div>
                                                    </div>
                                                    <div class="quest-progress-meta">
                                                        <span>@Math.Min(quest.ProgressCount, quest.TargetCount) / @quest.TargetCount</span>
                                                        <span class="quest-status">@GetQuestStatusLabel(quest)</span>
                                                    </div>
                                                </div>

                                                @if (quest.CanClaimReward)
                                                {
                                                    <button class="action primary quest-claim-button"
                                                            type="button"
                                                            disabled="@_claimBusyQuestIds.Contains(quest.UserQuestProgressId)"
                                                            @onclick="() => ClaimQuestRewardAsync(quest.UserQuestProgressId)">
                                                        Claim +@quest.RewardXp XP
                                                    </button>
                                                }
                                            </article>
                                        }
                                    }
                                </section>
                            }
                        </div>
                    </article>
                }
                else
                {
                    <article class="ocean-glass progression-card">
                        <h2>Progression unavailable</h2>
                        <p class="muted">Progression data could not be loaded.</p>
                        <button class="action secondary" type="button" @onclick="ReloadProgressionAsync">Retry progression</button>
                    </article>
                }
            </section>
        }

        @if (!string.IsNullOrWhiteSpace(_actionError))
        {
            <section class="ocean-glass state-card compact-state">
                <p class="muted">@_actionError</p>
            </section>
        }

        <section class="profile-section achievements-section">
            <div class="section-header">
                <h2>Achievements</h2>
                @if (_earned.Count > 0 || _locked.Count > 0)
                {
                    <span class="achievement-progress-badge">@_earned.Count <span class="progress-sep">/</span> @(_earned.Count + _locked.Count)</span>
                }
            </div>

            @if (_earned.Count == 0)
            {
                <div class="ocean-glass achievement-empty">
                    <span class="achievement-empty-icon">🎣</span>
                    <div>
                        <div class="achievement-empty-title">No achievements yet</div>
                        <div class="muted">Get fishing to earn your first badge!</div>
                    </div>
                </div>
            }
            else
            {
                <div class="achievement-grid">
                    @foreach (var a in _earned)
                    {
                        <article class="ocean-glass achievement-card earned">
                            <div class="achievement-icon">@GetAchievementEmoji(a.Key)</div>
                            <div class="achievement-body">
                                <div class="achievement-title">@a.Title</div>
                                @if (!string.IsNullOrWhiteSpace(a.Description))
                                {
                                    <div class="achievement-desc">@a.Description</div>
                                }
                                @if (a.EarnedAt.HasValue)
                                {
                                    <div class="achievement-date">✓ @a.EarnedAt.Value.ToLocalTime().ToString("MMM d, yyyy")</div>
                                }
                            </div>
                        </article>
                    }
                </div>
            }

            @if (_locked.Count > 0)
            {
                <button class="locked-toggle-btn" type="button" @onclick="() => _showLocked = !_showLocked">
                    <span>@(_showLocked ? "Hide" : "Show") locked (@_locked.Count)</span>
                    <span class="toggle-chevron @(_showLocked ? "chevron-open" : string.Empty)">›</span>
                </button>

                @if (_showLocked)
                {
                    <div class="achievement-grid locked-grid">
                        @foreach (var a in _locked)
                        {
                            <article class="ocean-glass achievement-card locked">
                                <div class="achievement-icon locked-icon">@GetAchievementEmoji(a.Key)</div>
                                <div class="achievement-body">
                                    <div class="achievement-title">@a.Title</div>
                                    @if (!string.IsNullOrWhiteSpace(a.Description))
                                    {
                                        <div class="achievement-desc">@a.Description</div>
                                    }
                                </div>
                            </article>
                        }
                    </div>
                }
            }
        </section>

        <section class="profile-feed">
            <div class="feed-header">
                <h2>@(IsViewingOtherUser ? "Catches" : "Your catches")</h2>
                <a href="/" class="feed-link">Back to home</a>
            </div>

            @if (_catchItems.Count == 0)
            {
                <section class="ocean-glass state-card compact-state">
                    <p class="muted">No catches posted yet.</p>
                </section>
            }
            else
            {
                <div class="catch-list">
                    @foreach (var catchItem in _catchItems)
                    {
                        <article class="ocean-glass profile-catch-card">
                            <div class="catch-head">
                                <a class="catch-user" href="@GetProfileRoute(catchItem.Username)">
                                    @DisplayNameFor(catchItem.DisplayName, catchItem.Username)
                                </a>
                                <span class="muted catch-time">@catchItem.CaughtAt.ToLocalTime().ToString("g")</span>
                            </div>

                            <div class="catch-species">
                                <a class="catch-species-link" href="/fish/@catchItem.CatchId">@catchItem.SpeciesCommonName</a>
                            </div>
                            <div class="catch-meta">
                                <span>@FormatLength(catchItem.LengthMeters)</span>
                                <span>@FormatWeight(catchItem.WeightKg)</span>
                            </div>

                            <div class="catch-actions">
                                @if (!IsViewingOtherUser)
                                {
                                    <button class="action @GetFavoriteActionClass(catchItem) profile-action-button"
                                            type="button"
                                            disabled="@_favoriteBusyCatchIds.Contains(catchItem.CatchId)"
                                            @onclick="() => ToggleFavoriteAsync(catchItem.CatchId)">
                                        @(catchItem.IsFavorite ? "★ Favorite" : "☆ Favorite")
                                    </button>
                                }
                                <button class="action @GetReactionActionClass(catchItem) profile-action-button"
                                        type="button"
                                        disabled="@_reactionBusyCatchIds.Contains(catchItem.CatchId)"
                                        @onclick="() => ToggleReactionAsync(catchItem.CatchId)">
                                    @(catchItem.ViewerHasReacted ? "Unlike" : "Like") · @catchItem.ReactionCount
                                </button>
                            </div>

                            <div class="comment-panel">
                                <div class="muted comment-count">
                                    @catchItem.CommentCount comments ·
                                    <a class="view-all-link" href="/fish/@catchItem.CatchId">View all</a>
                                </div>

                                @if (catchItem.RecentComments.Count == 0)
                                {
                                    <p class="muted empty-comments">No comments yet.</p>
                                }
                                else
                                {
                                    <ul class="comment-list">
                                        @foreach (var comment in catchItem.RecentComments)
                                        {
                                            <li>
                                                <div class="comment-meta-row">
                                                    <span class="comment-user">@DisplayNameFor(comment.DisplayName, comment.Username)</span>
                                                    <span class="comment-time">
                                                        @comment.CommentedAt.ToLocalTime().ToString("MMM d, h:mm tt")
                                                        @if (comment.EditedAt.HasValue)
                                                        {
                                                            <span class="edited-badge">edited</span>
                                                        }
                                                    </span>
                                                </div>
                                                <span class="comment-text">@comment.CommentText</span>
                                                @if (comment.UserId == _currentUser!.Id)
                                                {
                                                    <button class="comment-delete-btn"
                                                            type="button"
                                                            disabled="@_deleteBusyCommentIds.Contains(comment.Id)"
                                                            @onclick="() => DeleteCommentAsync(catchItem.CatchId, comment.Id)">Delete</button>
                                                }
                                            </li>
                                        }
                                    </ul>
                                }

                                <div class="comment-composer">
                                    <input class="comment-input"
                                           maxlength="500"
                                           placeholder="Add a comment…"
                                           value="@GetCommentDraft(catchItem.CatchId)"
                                           @oninput="e => UpdateCommentDraft(catchItem.CatchId, e.Value?.ToString())" />
                                    <button class="action secondary comment-submit"
                                            type="button"
                                            disabled="@(!CanSubmitComment(catchItem.CatchId))"
                                            @onclick="() => AddCommentAsync(catchItem.CatchId)">
                                        Comment
                                    </button>
                                </div>
                            </div>
                        </article>
                    }
                </div>
            }
        </section>
    }

    <BottomNav />
</div>

@code {
    [Parameter]
    public string? Username { get; set; }

    private SocialUserLookupDto? _currentUser;
    private SocialProfileSummaryDto? _profile;
    private ProgressionOverviewDto? _progressionOverview;
    private List<ProfileCatchItem> _catchItems = [];
    private List<AchievementStatusDto> _earned = [];
    private List<AchievementStatusDto> _locked = [];
    private bool _showLocked;
    private readonly Dictionary<Guid, string> _commentDrafts = [];
    private readonly HashSet<Guid> _reactionBusyCatchIds = [];
    private readonly HashSet<Guid> _commentBusyCatchIds = [];
    private readonly HashSet<Guid> _deleteBusyCommentIds = [];
    private List<FishingQuestProgressDto> _activeQuests = [];
    private readonly HashSet<Guid> _favoriteBusyCatchIds = [];
    private readonly HashSet<Guid> _claimBusyQuestIds = [];
    private static readonly QuestCadence[] QuestCadenceDisplayOrder =
    [
        QuestCadence.Daily,
        QuestCadence.Weekly,
        QuestCadence.Monthly
    ];
    private bool _isLoading = true;
    private bool _isProgressionLoading;
    private bool _isFollowBusy;
    private string? _loadError;
    private string? _actionError;
    private string? _progressionError;

    private bool IsViewingOtherUser =>
        _currentUser is not null &&
        _profile is not null &&
        _profile.UserId != _currentUser.Id;

    protected override async Task OnParametersSetAsync()
    {
        await LoadProfileAsync();
    }

    private async Task LoadProfileAsync()
    {
        _isLoading = true;
        _isFollowBusy = false;
        _loadError = null;
        _actionError = null;
        _profile = null;
        _progressionOverview = null;
        _activeQuests = [];
        _progressionError = null;
        _isProgressionLoading = false;
        _catchItems = [];
        _earned = [];
        _locked = [];
        _showLocked = false;
        _commentDrafts.Clear();
        _reactionBusyCatchIds.Clear();
        _commentBusyCatchIds.Clear();
        _favoriteBusyCatchIds.Clear();
        _claimBusyQuestIds.Clear();
        _deleteBusyCommentIds.Clear();

        try
        {
            _currentUser = await SocialService.ResolveCurrentUserAsync();
            var requestedUsername = string.IsNullOrWhiteSpace(Username) ? null : Username.Trim();

            if (requestedUsername is null || requestedUsername.Equals(_currentUser.Username, StringComparison.OrdinalIgnoreCase))
            {
                _profile = await SocialService.GetProfileSummaryByIdAsync(_currentUser.Id, _currentUser.Id);
            }
            else
            {
                _profile = await SocialService.GetProfileSummaryByUsernameAsync(requestedUsername, _currentUser.Id);
            }

            if (_profile is not null)
            {
                var feedItems = await SocialService.GetUserFeedAsync(_profile.UserId, _currentUser.Id, 25);
                _catchItems = feedItems.Select(MapFeedItem).ToList();
                var all = await AchievementService.GetAllWithStatusAsync(_profile.UserId);
                _earned = all.Where(a => a.IsEarned).OrderBy(a => a.EarnedAt).ToList();
                _locked = all.Where(a => !a.IsEarned).ToList();

                if (_profile.UserId == _currentUser.Id)
                {
                    await LoadProgressionDataAsync(_currentUser.Id);
                }
            }
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ReloadAsync()
    {
        await LoadProfileAsync();
    }

    private async Task ReloadProgressionAsync()
    {
        if (_currentUser is null || _profile is null || _profile.UserId != _currentUser.Id)
        {
            return;
        }

        await LoadProgressionDataAsync(_currentUser.Id);
    }

    private async Task LoadProgressionDataAsync(Guid userId)
    {
        _isProgressionLoading = true;
        _progressionError = null;

        try
        {
            var progressionTask = ProgressionService.GetProgressionOverviewAsync(userId);
            var questsTask = FishingQuestService.GetActiveQuestsAsync(userId);
            await Task.WhenAll(progressionTask, questsTask);

            _progressionOverview = progressionTask.Result;
            _activeQuests = questsTask.Result
                .OrderBy(quest => quest.Cadence)
                .ThenBy(quest => quest.QuestName, StringComparer.OrdinalIgnoreCase)
                .ToList();
        }
        catch (Exception ex)
        {
            _progressionOverview = null;
            _activeQuests = [];
            _progressionError = ex.Message;
        }
        finally
        {
            _isProgressionLoading = false;
        }
    }

    private async Task ClaimQuestRewardAsync(Guid userQuestProgressId)
    {
        if (_currentUser is null || _claimBusyQuestIds.Contains(userQuestProgressId))
        {
            return;
        }

        _actionError = null;
        _claimBusyQuestIds.Add(userQuestProgressId);

        try
        {
            await FishingQuestService.ClaimRewardAsync(_currentUser.Id, userQuestProgressId);
            await LoadProgressionDataAsync(_currentUser.Id);
        }
        catch (Exception ex)
        {
            _actionError = ex.Message;
        }
        finally
        {
            _claimBusyQuestIds.Remove(userQuestProgressId);
        }
    }

    private async Task ToggleFollowAsync()
    {
        if (_currentUser is null || _profile is null || _profile.UserId == _currentUser.Id)
        {
            return;
        }

        _actionError = null;
        _isFollowBusy = true;

        try
        {
            var changed = _profile.IsFollowing
                ? await SocialService.UnfollowAsync(_currentUser.Id, _profile.UserId)
                : await SocialService.FollowAsync(_currentUser.Id, _profile.UserId);

            if (!changed)
            {
                return;
            }

            var followerCount = _profile.IsFollowing
                ? Math.Max(0, _profile.FollowerCount - 1)
                : _profile.FollowerCount + 1;

            _profile = _profile with
            {
                IsFollowing = !_profile.IsFollowing,
                FollowerCount = followerCount
            };
        }
        catch (Exception ex)
        {
            _actionError = ex.Message;
        }
        finally
        {
            _isFollowBusy = false;
        }
    }

    private async Task ToggleReactionAsync(Guid catchId)
    {
        if (_currentUser is null || _reactionBusyCatchIds.Contains(catchId))
        {
            return;
        }

        var catchItem = _catchItems.FirstOrDefault(c => c.CatchId == catchId);
        if (catchItem is null)
        {
            return;
        }

        _actionError = null;
        _reactionBusyCatchIds.Add(catchId);

        try
        {
            var result = await SocialService.ToggleReactionAsync(catchId, _currentUser.Id);
            catchItem.ViewerHasReacted = result.IsReacted;
            catchItem.ReactionCount = result.ReactionCount;
        }
        catch (Exception ex)
        {
            _actionError = ex.Message;
        }
        finally
        {
            _reactionBusyCatchIds.Remove(catchId);
        }
    }

    private async Task ToggleFavoriteAsync(Guid catchId)
    {
        if (_currentUser is null || _favoriteBusyCatchIds.Contains(catchId))
        {
            return;
        }

        var catchItem = _catchItems.FirstOrDefault(c => c.CatchId == catchId);
        if (catchItem is null)
        {
            return;
        }

        _actionError = null;
        _favoriteBusyCatchIds.Add(catchId);

        try
        {
            await CatchService.SetCatchFavoriteAsync(catchId, _currentUser.Id, !catchItem.IsFavorite);
            catchItem.IsFavorite = !catchItem.IsFavorite;
        }
        catch (Exception ex)
        {
            _actionError = ex.Message;
        }
        finally
        {
            _favoriteBusyCatchIds.Remove(catchId);
        }
    }

    private async Task AddCommentAsync(Guid catchId)
    {
        if (_currentUser is null || _commentBusyCatchIds.Contains(catchId))
        {
            return;
        }

        var catchItem = _catchItems.FirstOrDefault(c => c.CatchId == catchId);
        if (catchItem is null)
        {
            return;
        }

        var draft = GetCommentDraft(catchId);
        if (string.IsNullOrWhiteSpace(draft))
        {
            return;
        }

        _actionError = null;
        _commentBusyCatchIds.Add(catchId);

        try
        {
            var comment = await SocialService.AddCommentAsync(catchId, _currentUser.Id, draft);
            catchItem.CommentCount += 1;
            catchItem.RecentComments = NormalizeRecentComments(catchItem.RecentComments.Append(comment));
            _commentDrafts[catchId] = string.Empty;
        }
        catch (Exception ex)
        {
            _actionError = ex.Message;
        }
        finally
        {
            _commentBusyCatchIds.Remove(catchId);
        }
    }

    private async Task DeleteCommentAsync(Guid catchId, Guid commentId)
    {
        if (_currentUser is null || _deleteBusyCommentIds.Contains(commentId))
        {
            return;
        }

        var catchItem = _catchItems.FirstOrDefault(c => c.CatchId == catchId);
        if (catchItem is null)
        {
            return;
        }

        _actionError = null;
        _deleteBusyCommentIds.Add(commentId);

        try
        {
            await SocialService.DeleteCommentAsync(commentId, _currentUser.Id);
            catchItem.CommentCount = Math.Max(0, catchItem.CommentCount - 1);
            catchItem.RecentComments.RemoveAll(c => c.Id == commentId);
        }
        catch (Exception ex)
        {
            _actionError = ex.Message;
        }
        finally
        {
            _deleteBusyCommentIds.Remove(commentId);
        }
    }

    private static ProfileCatchItem MapFeedItem(SocialCatchFeedItemDto dto)
    {
        return new ProfileCatchItem
        {
            CatchId = dto.CatchId,
            UserId = dto.UserId,
            Username = dto.Username,
            DisplayName = dto.DisplayName,
            CaughtAt = dto.CaughtAt,
            SpeciesCommonName = dto.SpeciesCommonName,
            LengthMeters = dto.LengthMeters,
            WeightKg = dto.WeightKg,
            ReactionCount = dto.ReactionCount,
            CommentCount = dto.CommentCount,
            ViewerHasReacted = dto.ViewerHasReacted,
            IsFavorite = dto.IsFavorite,
            RecentComments = NormalizeRecentComments(dto.RecentComments)
        };
    }

    private static List<SocialCommentDto> NormalizeRecentComments(IEnumerable<SocialCommentDto> comments)
    {
        return comments
            .OrderByDescending(c => c.CommentedAt)
            .Take(3)
            .OrderBy(c => c.CommentedAt)
            .ToList();
    }

    private string GetPageTitle()
    {
        if (_profile is null)
        {
            return "Profile · Hooked";
        }

        return $"{DisplayNameFor(_profile.DisplayName, _profile.Username)} · Hooked";
    }

    private static string DisplayNameFor(string? displayName, string username)
    {
        return string.IsNullOrWhiteSpace(displayName) ? username : displayName;
    }

    private static string FormatLength(double? lengthMeters)
    {
        return lengthMeters.HasValue ? $"{lengthMeters.Value:F2} m" : "Length —";
    }

    private static string FormatWeight(double? weightKg)
    {
        return weightKg.HasValue ? $"{weightKg.Value:F2} kg" : "Weight —";
    }

    private string GetReactionActionClass(ProfileCatchItem catchItem)
    {
        return catchItem.ViewerHasReacted ? "primary" : "secondary";
    }

    private string GetFavoriteActionClass(ProfileCatchItem catchItem)
    {
        return catchItem.IsFavorite ? "primary" : "secondary";
    }

    private string GetProfileRoute(string username)
    {
        if (string.IsNullOrWhiteSpace(username))
        {
            return "/profile";
        }

        if (_currentUser is not null && username.Equals(_currentUser.Username, StringComparison.OrdinalIgnoreCase))
        {
            return "/profile";
        }

        return $"/profile/{Uri.EscapeDataString(username)}";
    }

    private string GetCommentDraft(Guid catchId)
    {
        return _commentDrafts.TryGetValue(catchId, out var draft) ? draft : string.Empty;
    }

    private void UpdateCommentDraft(Guid catchId, string? value)
    {
        _commentDrafts[catchId] = value ?? string.Empty;
    }

    private bool CanSubmitComment(Guid catchId)
    {
        return !_commentBusyCatchIds.Contains(catchId) &&
               !string.IsNullOrWhiteSpace(GetCommentDraft(catchId));
    }

    private List<FishingQuestProgressDto> GetQuestsByCadence(QuestCadence cadence)
    {
        return _activeQuests
            .Where(quest => quest.Cadence == cadence)
            .ToList();
    }

    private static string GetCadenceLabel(QuestCadence cadence)
    {
        return cadence switch
        {
            QuestCadence.Daily => "Daily",
            QuestCadence.Weekly => "Weekly",
            QuestCadence.Monthly => "Monthly",
            _ => "Other"
        };
    }

    private static int GetQuestProgressPercent(FishingQuestProgressDto quest)
    {
        if (quest.TargetCount <= 0)
        {
            return 0;
        }

        var progress = Math.Min(quest.ProgressCount, quest.TargetCount);
        return Math.Clamp((int)Math.Round((progress / (double)quest.TargetCount) * 100), 0, 100);
    }

    private static string GetQuestStatusLabel(FishingQuestProgressDto quest)
    {
        if (quest.RewardClaimedAtUtc.HasValue)
        {
            return "Claimed";
        }

        if (quest.CanClaimReward)
        {
            return "Ready to claim";
        }

        return "In progress";
    }

    private static int GetXpProgressPercent(ProgressionOverviewDto progression)
    {
        if (progression.IsAtMaxLevel)
        {
            return 100;
        }

        if (progression.XpRequiredForNextLevel <= 0)
        {
            return 0;
        }

        return Math.Clamp((int)Math.Round((progression.CurrentXp / (double)progression.XpRequiredForNextLevel) * 100), 0, 100);
    }

    private static string GetXpProgressLabel(ProgressionOverviewDto progression)
    {
        if (progression.IsAtMaxLevel)
        {
            return "Max level reached";
        }

        return $"{progression.CurrentXp}/{progression.XpRequiredForNextLevel} XP to next level";
    }

