    private static string RenderMarkdown(string md)
    {
        if (string.IsNullOrWhiteSpace(md)) return string.Empty;

        var lines = md.Split('\n');
        var sb = new System.Text.StringBuilder();
        bool inList = false;

        foreach (var rawLine in lines)
        {
            var line = rawLine.TrimEnd();

            line = System.Text.RegularExpressions.Regex.Replace(line, @"\*\*(.+?)\*\*", "<strong>$1</strong>");
            line = System.Text.RegularExpressions.Regex.Replace(line, @"\*(.+?)\*", "<em>$1</em>");

            if (line.StartsWith("- ") || line.StartsWith("* "))
            {
                if (!inList) { sb.Append("<ul>"); inList = true; }
                sb.Append($"<li>{line[2..]}</li>");
            }
            else
            {
                if (inList) { sb.Append("</ul>"); inList = false; }
                if (!string.IsNullOrWhiteSpace(line))
                    sb.Append($"<p>{line}</p>");
            }
        }
        if (inList) sb.Append("</ul>");
        return sb.ToString();
    }

