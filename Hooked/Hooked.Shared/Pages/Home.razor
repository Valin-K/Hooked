@page "/"
@using Hooked.Shared.Data
@using Hooked.Shared.Services
@inject ICatchService CatchService
@inject IFishService FishService
@inject IUserService UserService

<PageTitle>Hooked</PageTitle>

<div class="mobile-shell">
    <TopNavBar Subtitle="Ocean Intelligence" />

    <section class="hero ocean-glass">
        <div class="badge-pill">AI-Powered Catch Hub</div>
        <h1 class="welcome">Dive into your next trophy catch.</h1>
        <div class="subtitle">Track catches, map hotspots, and identify species in a single fluid workspace.</div>
        <div class="hero-actions">
            <button class="action primary" @onclick="ScanFish">Open AI Scanner</button>
            <button class="action secondary" @onclick="GoToFishDex">Browse FishDex</button>
        </div>
    </section>

    <section class="stats-grid">
        <article class="stat-card ocean-glass">
            <div class="stat-label">Recent Catches</div>
            <div class="stat-value">@recentCatchCount</div>
        </article>
        <article class="stat-card ocean-glass">
            <div class="stat-label">Today's Catches</div>
            <div class="stat-value">@todayCatchCount</div>
        </article>
        <article class="stat-card ocean-glass">
            <div class="stat-label">Best Length</div>
            <div class="stat-value">@longestCatchText</div>
        </article>
    </section>

    <section class="ai-highlight ocean-glass">
        <div>
            <div class="ai-title">Tide AI Assistant</div>
            <div class="ai-text">Use camera-first recognition with contextual species hints to reduce misidentifications in the field.</div>
        </div>
        <button class="action primary compact" @onclick="ScanFish">Launch</button>
    </section>

    <section class="recent">
        <h3>Recent catches</h3>
        @if (!string.IsNullOrWhiteSpace(loadErrorMessage))
        {
            <p class="muted">@loadErrorMessage</p>
        }
        else if (recentCatches is null)
        {
            <p class="muted">Loading…</p>
        }
        else if (!recentCatches.Any())
        {
            <p class="muted">No catches yet — start by scanning a fish.</p>
        }
        else
        {
            <div class="recent-list">
                @foreach (var c in recentCatches)
                {
                    <article class="catch-card" @onclick="() => OpenCatch(c.Id)">
                        <div class="catch-photo" aria-hidden="true">
                            <AppIcon Name='@((c.PhotoPath is null) ? "fish" : "image")' Size="16" />
                        </div>
                        <div class="catch-meta">
                            <div class="species">@c.Species?.CommonName</div>
                            <div class="details">@((c.LengthMeters.HasValue) ? ($"{c.LengthMeters:F2} m") : "—") • @c.CaughtAt.ToLocalTime().ToString("g")</div>
                        </div>
                    </article>
                }
            </div>
        }
    </section>

    <bottom-nav />
</div>

@code {
    private IEnumerable<Hooked.Shared.Data.CatchRecord>? recentCatches;
    private string? loadErrorMessage;
    private int recentCatchCount;
    private int todayCatchCount;
    private string longestCatchText = "—";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            recentCatches = await CatchService.GetRecentCatchesAsync(20);

            var catchList = recentCatches?.ToList() ?? [];
            recentCatchCount = catchList.Count;
            todayCatchCount = catchList.Count(c => c.CaughtAt.ToLocalTime().Date == DateTime.Today);

            var longestCatch = catchList
                .Where(c => c.LengthMeters.HasValue)
                .Select(c => c.LengthMeters!.Value)
                .DefaultIfEmpty()
                .Max();

            if (longestCatch > 0)
            {
                longestCatchText = $"{longestCatch:F2} m";
            }
        }
        catch (Exception)
        {
            recentCatches = [];
            loadErrorMessage = "Could not load catches right now.";
        }
    }

    private void ScanFish()
    {
        NavigationManager.NavigateTo("/arscanner");
    }

    [Inject]
    public NavigationManager NavigationManager { get; set; } = null!;

    private void GoToFishDex() => NavigationManager.NavigateTo("/fishdex");
    private void OpenCatch(Guid id) => NavigationManager.NavigateTo($"/fish/{id}");
}
