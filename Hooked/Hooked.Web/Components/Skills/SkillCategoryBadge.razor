@using Hooked.Shared.Data

<div class="skill-category-badge @GetBadgeClass()">
    <span class="badge-icon" aria-hidden="true">
        <AppIcon Name="@GetIconName()" Size="@GetIconSize()" />
    </span>
    @if (ShowLabel)
    {
        <span class="badge-label">@GetCategoryLabel()</span>
    }
</div>

<style scoped>
.skill-category-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: var(--font-size-sm);
    font-weight: 600;
    white-space: nowrap;
}

.skill-category-badge.xs {
    padding: 0.125rem 0.5rem;
    gap: 0.25rem;
}

.skill-category-badge.sm {
    padding: 0.25rem 0.625rem;
    gap: 0.375rem;
}

.skill-category-badge.md {
    padding: 0.375rem 0.875rem;
    gap: 0.5rem;
}

.skill-category-badge.lg {
    padding: 0.5rem 1rem;
    gap: 0.625rem;
}

.skill-category-badge.fishing-method {
    background-color: rgba(59, 130, 246, 0.1);
    color: rgb(59, 130, 246);
}

.skill-category-badge.species {
    background-color: rgba(34, 197, 94, 0.1);
    color: rgb(34, 197, 94);
}

.skill-category-badge.community {
    background-color: rgba(236, 72, 153, 0.1);
    color: rgb(236, 72, 153);
}

.skill-category-badge.exploration {
    background-color: rgba(249, 115, 22, 0.1);
    color: rgb(249, 115, 22);
}

.skill-category-badge.general {
    background-color: rgba(249, 115, 22, 0.1);
    color: rgb(249, 115, 22);
}

.badge-icon {
    display: flex;
    align-items: center;
    justify-content: center;
}

.badge-label {
    font-weight: 500;
}
</style>

@code {
    [Parameter]
    public SkillCategory Category { get; set; } = SkillCategory.FishingMethod;

    [Parameter]
    public string Size { get; set; } = "md";

    [Parameter]
    public bool ShowLabel { get; set; } = true;

    private string GetBadgeClass()
    {
        var sizeClass = Size.ToLower() switch
        {
            "xs" => "xs",
            "sm" => "sm",
            "md" => "md",
            "lg" => "lg",
            _ => "md"
        };

        var categoryClass = Category switch
        {
            SkillCategory.FishingMethod => "fishing-method",
            SkillCategory.SpeciesKnowledge => "species",
            SkillCategory.Community => "community",
            SkillCategory.Exploration => "exploration",
            _ => "general"
        };

        return $"{sizeClass} {categoryClass}";
    }

    private string GetCategoryLabel()
    {
        return Category switch
        {
            SkillCategory.FishingMethod => "Technique",
            SkillCategory.SpeciesKnowledge => "Species",
            SkillCategory.Community => "Community",
            SkillCategory.Exploration => "Exploration",
            _ => "Skill"
        };
    }

    private string GetIconName()
    {
        return Category switch
        {
            SkillCategory.FishingMethod => "book-open",
            SkillCategory.SpeciesKnowledge => "fish",
            SkillCategory.Community => "feed",
            SkillCategory.Exploration => "map",
            _ => "help"
        };
    }

    private int GetIconSize()
    {
        return Size.ToLower() switch
        {
            "xs" => 12,
            "sm" => 14,
            "md" => 16,
            "lg" => 18,
            _ => 16
        };
    }
}
