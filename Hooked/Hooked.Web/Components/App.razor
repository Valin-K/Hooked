<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <script>
        (function () {
            try {
                var key = "hooked-theme";
                var saved = localStorage.getItem(key);
                var resolved = (saved === "dark" || saved === "light")
                    ? saved
                    : ((window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches) ? "dark" : "light");
                document.documentElement.setAttribute("data-theme", resolved);
            } catch {
                document.documentElement.setAttribute("data-theme", "dark");
            }
        })();
    </script>
    <ResourcePreloader />
    <link rel="stylesheet" href="_content/Hooked.Shared/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://api.mapbox.com/mapbox-gl-js/v3.4.0/mapbox-gl.css" />
    <link rel="stylesheet" href="https://unpkg.com/lucide-static@latest/font/lucide.css" />
    <link rel="stylesheet" href="_content/Hooked.Shared/app.css" />
    <link rel="stylesheet" href="_content/Hooked.Shared/mobile.css" />
    <link rel="stylesheet" href="Hooked.Web.styles.css" />
    <ImportMap />
    <link rel="icon" type="image/png" href="_content/Hooked.Shared/favicon.png" />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <ReconnectModal />
    <script src="_content/Hooked.Shared/theme.js"></script>
    <script src="_content/Hooked.Shared/geo-interop.js"></script>
    <script src="https://api.mapbox.com/mapbox-gl-js/v3.4.0/mapbox-gl.js"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>
